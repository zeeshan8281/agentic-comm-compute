# --- Service ---
SERVICE_NAME=agentic-commerce-compte
PORT=8080
LOG_LEVEL=info

# --- Model routing ---
# Default: direct Anthropic. Set AI_GATEWAY_API_KEY (and clear ANTHROPIC_API_KEY)
# to route via Vercel AI Gateway with a `provider/model` AGENT_MODEL instead.
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# --- Agent wallet (signs USDC payments to merchants) ---
# v1 uses a raw private key. v2 swaps to CDP Wallet smart wallet for policy caps.
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# --- Network ---
# Base mainnet: eip155:8453 / base  (default — real x402 merchants are mainnet)
# Base Sepolia: eip155:84532 / base-sepolia  (dev only)
X402_NETWORK=base
BASE_RPC_URL=https://mainnet.base.org

# --- Spend caps (enforced in agent code in v1; CDP policy layer in v2) ---
# Per-payment 25 to allow a $20 StableMerch shirt + slack for facilitator fees.
CAP_PER_PAYMENT_USDC=25
CAP_PER_SESSION_USDC=30
CAP_PER_DAY_USDC=60
# HITL kicks in above 1 USDC — anything cheap (Satoshi, twit.sh, Reddit) runs without prompting.
HITL_THRESHOLD_USDC=1

# --- EigenCompute attestation (injected at TEE boot) ---
GIT_SHA=local-dev
BUILD_TIME=
ECLOUD_APP_ID=
ECLOUD_ATTESTATION_HASH=

# --- Demo HITL ---
# When true, the /api/confirm endpoint auto-approves. Demo mode only.
HITL_AUTO_APPROVE=false

# --- StableMerch order (only required when buying stablemerch-shirt / stablemerch-mug) ---
# Public URL of the image to print on the shirt. Must be reachable from the printer.
STABLEMERCH_IMAGE_URL=
STABLEMERCH_RECIPIENT_NAME=
STABLEMERCH_ADDRESS1=
STABLEMERCH_ADDRESS2=
STABLEMERCH_CITY=
STABLEMERCH_STATE=
STABLEMERCH_ZIP=
STABLEMERCH_COUNTRY=US
STABLEMERCH_SHIRT_SIZE=M

# --- Cryptorefills order (gift cards, mobile top-ups, ~10k brands / 180 countries) ---
# Country scopes the brand catalog. Default 'in' (India — Swiggy/Zomato/Phonepe/
# Airtel/Jio etc). EMAIL is where the voucher delivery email lands.
# BENEFICIARY is the account being topped up: same email for digital gift cards,
# or a phone number for mobile recharge.
CRYPTOREFILLS_COUNTRY=in
CRYPTOREFILLS_EMAIL=
CRYPTOREFILLS_BENEFICIARY=

# --- Rye Universal Checkout (US-only physical goods) ---
# Required when the agent buys a physical product via rye_buy. The model
# never sees these — the rye_buy tool injects them into the checkout-intent
# body server-side. Country must be US (Rye does not ship internationally).
RYE_FIRST_NAME=
RYE_LAST_NAME=
RYE_EMAIL=
RYE_PHONE=
RYE_ADDRESS1=
RYE_ADDRESS2=
RYE_CITY=
RYE_STATE=
RYE_ZIP=
RYE_COUNTRY=US

# --- Telegram bot (optional) ---
# When set, launches the conversational Telegram bot alongside the HTTP API.
# Each chat owns its own profile in data/users.json — phone + email are
# stored per-chat and injected into cryptorefills_buy as userConfig, so the
# model never sees PII even when serving many users.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# TLS Configuration
# DOMAIN=yourdomain.com
# APP_PORT=3000
# ENABLE_CADDY_LOGS=false
# ACME_STAGING=false
# ACME_FORCE_ISSUE=false
