# Supabase project URL — looks like https://<ref>.supabase.co
SUPABASE_URL=

# Service-role key. WRITE-ONLY use server-side; never expose to the browser.
# Settings → API → service_role secret (the one labeled "secret").
SUPABASE_SERVICE_ROLE_KEY=

# Optional override; defaults to "waitlist". Run the SQL in README.md to
# create the table before flipping these vars on.
SUPABASE_WAITLIST_TABLE=waitlist
